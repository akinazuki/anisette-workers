{
  "name": "anisette-workers",
  "version": "0.1.0",
  "description": "Run @lbr77/anisette-js on Cloudflare Workers. Generates Apple Anisette headers via WASM unicorn ARM64 emulation.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./extract-wasm": "./scripts/extract-wasm.mjs",
    "./patch-wasm-memory": "./scripts/patch-wasm-memory.mjs"
  },
  "bin": {
    "anisette-extract-wasm": "./scripts/extract-wasm.mjs",
    "anisette-patch-wasm": "./scripts/patch-wasm-memory.mjs"
  },
  "files": [
    "src",
    "scripts",
    "README.md"
  ],
  "peerDependencies": {
    "@lbr77/anisette-js": "^0.1.3"
  },
  "keywords": [
    "anisette",
    "apple",
    "icloud",
    "cloudflare",
    "workers",
    "wasm"
  ],
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1"
  }
}
